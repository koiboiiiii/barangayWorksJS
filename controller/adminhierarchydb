BEGIN
	INSERT INTO dbo.admin_users (username, password_plaintext, display_name, email, role_id, is_active)
	VALUES (
		'supervisor',
		'Supervisor123!',
		'Supervisor Admin',
		'supervisor@barangayworks.local',
		@SupervisorRoleId,
		1
	);
END;

UPDATE dbo.admin_users
SET password_plaintext = 'Supervisor123!'
WHERE username = 'supervisor'
  AND (password_plaintext IS NULL OR LTRIM(RTRIM(password_plaintext)) = '');

SELECT
	u.username,
	u.display_name,
	r.role_name,
	p.can_click_btnmanageaccess,
	p.can_click_btnschedules,
	p.can_click_btnlogs,
	p.can_click_btndbconfig,
	p.can_click_btnpermission,
	p.can_click_btnnewuser,
	p.can_click_btnimport,
	p.can_click_btnexport
FROM dbo.admin_users u
JOIN dbo.admin_roles r ON r.id = u.role_id
JOIN dbo.admin_role_permissions p ON p.role_id = r.id
WHERE u.username = 'supervisor';
