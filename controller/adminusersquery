
USE [barangayworks];

-- Admin users query: returns users joined with role and permissions
-- Usage: set @username to filter a single user, or leave NULL to return all users.

SET NOCOUNT ON;

DECLARE @username NVARCHAR(100) = NULL; -- e.g. 'koi' or NULL

SELECT
	u.username,
	u.display_name,
	u.barangay_id,
	u.is_active,
	r.role_name,
	u.created_at,
	u.updated_at
FROM dbo.admin_users u
JOIN dbo.admin_roles r ON r.id = u.role_id
LEFT JOIN dbo.admin_role_permissions p ON p.role_id = r.id
-- Always exclude the built-in 'admin' account from this query
WHERE (@username IS NULL OR u.username = @username)
	AND u.username <> 'admin'
ORDER BY u.username;

