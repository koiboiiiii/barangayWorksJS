{
  "name": "barangayworksjs",
  "version": "1.0.0",
  "private": true,
  "main": "controller/controller.js",
  "scripts": {
    "start": "node -e \"require('./controller/controller').startServer()\" & sleep 2 && open http://localhost:3000",
    "stop": "sh -c 'pid=$(lsof -tiTCP:3000 -sTCP:LISTEN -Pn); if [ -n \"$pid\" ]; then kill $pid && echo \"Stopped server process: $pid\"; else echo \"No server process is listening on port 3000\"; fi'",
    "dev": "nodemon -e \"node -e 'require(\\\"./controller/controller\\\").startServer()'\""
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "mssql": "^11.0.1",
    "nodemailer": "^8.0.9"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
